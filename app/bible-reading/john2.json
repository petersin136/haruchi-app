  "chapters": [
    {
      "chapter": 1,
      "title": "사랑 안에 행하라",
      "verses": {
        "krv": [
          {
            "n": 1,
            "t": "장로는 택하심을 입은 부녀와 그의 자녀에게 편지하노니 내가 참으로 사랑하는 자요 나뿐 아니라 진리를 아는 모든 자도 그리하는 것은"
          },
          {
            "n": 2,
            "t": "우리 안에 거하여 영원히 우리와 함께 할 진리를 인함이로다"
          },
          {
            "n": 3,
            "t": "은혜와 긍휼과 평강이 하나님 아버지와 아버지의 아들 예수 그리스도께로부터 진리와 사랑 가운데서 우리와 함께 있으리라"
          },
          {
            "n": 4,
            "t": "너의 자녀 중에 우리가 아버지께 받은 계명대로 진리에 행하는 자를 내가 보니 심히 기쁘도다"
          },
          {
            "n": 5,
            "t": "부녀여, 내가 이제 네게 구하노니 서로 사랑하자 이는 새 계명 같이 네게 쓰는 것이 아니요 오직 처음부터 우리가 가진 것이라"
          },
          {
            "n": 6,
            "t": "또 사랑은 이것이니 우리가 그 계명을 좇아 행하는 것이요 계명은 이것이니 너희가 처음부터 들은 바와 같이 그 가운데서 행하라 하심이라"
          },
          {
            "n": 7,
            "t": "미혹하는 자가 많이 세상에 나왔나니 이는 예수 그리스도께서 육체로 임하심을 부인하는 자라 이것이 미혹하는 자요 적그리스도니"
          },
          {
            "n": 8,
            "t": "너희는 너희를 삼가 우리의 일한 것을 잃지 말고 오직 온전한 상을 얻으라"
          },
          {
            "n": 9,
            "t": "지내쳐 그리스도 교훈 안에 거하지 아니하는 자마다 하나님을 모시지 못하되 교훈 안에 거하는 이 사람이 아버지와 아들을 모시느니라"
          },
          {
            "n": 10,
            "t": "누구든지 이 교훈을 가지지 않고 너희에게 나아가거든 그를 집에 들이지도 말고 인사도 말라"
          },
          {
            "n": 11,
            "t": "그에게 인사하는 자는 그 악한 일에 참예하는 자임이니라"
          },
          {
            "n": 12,
            "t": "내가 너희에게 쓸 것이 많으나 종이와 먹으로 쓰기를 원치 아니하고 오히려 너희에게 가서 면대하여 말하려 하니 이는 너희 기쁨을 충만케 하려 함이라"
          },
          {
            "n": 13,
            "t": "택하심을 입은 네 자매의 자녀가 네게 문안하느니라"
          }
        ],
        "kids": [
          {
            "n": 1,
            "t": "장로(인 나)가 택하심을 받은 부인과 그녀의 자녀들에게 편지를 써요. 내가 진심으로 사랑하는 사람들이고, 나뿐 아니라 진리를 아는 모든 사람도 그렇게 사랑하는 것은,"
          },
          {
            "n": 2,
            "t": "우리 안에 머무르고 영원히 우리와 함께할 진리 때문이에요."
          },
          {
            "n": 3,
            "t": "은혜와 긍휼과 평강이 하나님 아버지와 아버지의 아들 예수 그리스도께로부터, 진리와 사랑 가운데서 우리와 함께하기를 빌어요."
          },
          {
            "n": 4,
            "t": "여러분의 자녀들 가운데서, 우리가 아버지께 받은 계명대로 진리 안에서 살아가고 있는 사람들을 내가 보고 매우 기뻤어요."
          },
          {
            "n": 5,
            "t": "부인이여, 이제 내가 당신에게 부탁해요. 우리가 서로 사랑해요. 이것은 새 계명을 쓰는 게 아니라, 우리가 처음부터 가지고 있던 그 계명이에요."
          },
          {
            "n": 6,
            "t": "또 사랑은 이거예요. 곧 그분의 계명을 따라 사는 거예요. 그 계명은 이거예요. 곧 여러분이 처음부터 들은 그대로, 그 안에서 살아가라는 거예요."
          },
          {
            "n": 7,
            "t": "미혹하는 사람이 많이 세상에 나왔어요. 그들은 예수 그리스도께서 육체로 오신 것을 부인하는 사람들이에요. 이런 사람이 미혹하는 자이고, 적그리스도예요."
          },
          {
            "n": 8,
            "t": "여러분은 자신을 잘 살펴서, 우리가 (지금까지) 일한 결과를 잃지 말고 온전한 상을 받으세요."
          },
          {
            "n": 9,
            "t": "누구든지 (가르침에서) 너무 멀리 나가서 그리스도의 가르침 안에 머물러 있지 않은 사람마다 하나님을 모시지 못하고, 그 가르침 안에 머물러 있는 사람만이 아버지와 아들을 모셔요."
          },
          {
            "n": 10,
            "t": "누구든지 이 가르침을 가지고 있지 않으면서 여러분에게 오면, 그를 집에 들이지도 말고 인사도 하지 마세요."
          },
          {
            "n": 11,
            "t": "그에게 인사하는 사람은 그의 악한 일에 함께 참여하는 사람이 되기 때문이에요."
          },
          {
            "n": 12,
            "t": "여러분에게 쓸 것이 많지만, 종이와 먹으로 쓰고 싶지 않아요. 오히려 여러분에게 가서 얼굴을 보고 이야기하기를 바라요. 이것은 우리의 기쁨을 충만하게 하려는 거예요."
          },
          {
            "n": 13,
            "t": "택하심을 받은 당신 자매의 자녀들이 당신에게 문안 인사를 보내요."
          }
        ],
        "greek": [
          {
            "n": 1,
            "t": "Ὁ πρεσβύτερος ἐκλεκτῇ κυρίᾳ καὶ τοῖς τέκνοις αὐτῆς, οὓς ἐγὼ ἀγαπῶ ἐν ἀληθείᾳ, καὶ οὐκ ἐγὼ μόνος ἀλλὰ καὶ πάντες οἱ ἐγνωκότες τὴν ἀλήθειαν,"
          },
          {
            "n": 2,
            "t": "διὰ τὴν ἀλήθειαν τὴν μένουσαν ἐν ἡμῖν, καὶ μεθ’ ἡμῶν ἔσται εἰς τὸν αἰῶνα·"
          },
          {
            "n": 3,
            "t": "ἔσται μεθ’ ἡμῶν χάρις ἔλεος εἰρήνη παρὰ θεοῦ πατρός, καὶ παρὰ Ἰησοῦ Χριστοῦ τοῦ υἱοῦ τοῦ πατρός, ἐν ἀληθείᾳ καὶ ἀγάπῃ."
          },
          {
            "n": 4,
            "t": "Ἐχάρην λίαν ὅτι εὕρηκα ἐκ τῶν τέκνων σου περιπατοῦντας ἐν ἀληθείᾳ, καθὼς ἐντολὴν ἐλάβομεν παρὰ τοῦ πατρός."
          },
          {
            "n": 5,
            "t": "καὶ νῦν ἐρωτῶ σε, κυρία, οὐχ ὡς ἐντολὴν καινὴν γράφων σοι ἀλλὰ ἣν εἴχομεν ἀπ’ ἀρχῆς, ἵνα ἀγαπῶμεν ἀλλήλους."
          },
          {
            "n": 6,
            "t": "καὶ αὕτη ἐστὶν ἡ ἀγάπη, ἵνα περιπατῶμεν κατὰ τὰς ἐντολὰς αὐτοῦ· αὕτη ἡ ἐντολή ἐστιν, καθὼς ἠκούσατε ἀπ’ ἀρχῆς, ἵνα ἐν αὐτῇ περιπατῆτε."
          },
          {
            "n": 7,
            "t": "ὅτι πολλοὶ πλάνοι ἐξῆλθον εἰς τὸν κόσμον, οἱ μὴ ὁμολογοῦντες Ἰησοῦν Χριστὸν ἐρχόμενον ἐν σαρκί· οὗτός ἐστιν ὁ πλάνος καὶ ὁ ἀντίχριστος."
          },
          {
            "n": 8,
            "t": "βλέπετε ἑαυτούς, ἵνα μὴ ἀπολέσητε ἃ εἰργασάμεθα, ἀλλὰ μισθὸν πλήρη ἀπολάβητε."
          },
          {
            "n": 9,
            "t": "πᾶς ὁ προάγων καὶ μὴ μένων ἐν τῇ διδαχῇ τοῦ Χριστοῦ θεὸν οὐκ ἔχει· ὁ μένων ἐν τῇ διδαχῇ, οὗτος καὶ τὸν πατέρα καὶ τὸν υἱὸν ἔχει."
          },
          {
            "n": 10,
            "t": "εἴ τις ἔρχεται πρὸς ὑμᾶς καὶ ταύτην τὴν διδαχὴν οὐ φέρει, μὴ λαμβάνετε αὐτὸν εἰς οἰκίαν καὶ χαίρειν αὐτῷ μὴ λέγετε·"
          },
          {
            "n": 11,
            "t": "ὁ λέγων γὰρ αὐτῷ χαίρειν κοινωνεῖ τοῖς ἔργοις αὐτοῦ τοῖς πονηροῖς."
          },
          {
            "n": 12,
            "t": "Πολλὰ ἔχων ὑμῖν γράφειν οὐκ ἐβουλήθην διὰ χάρτου καὶ μέλανος, ἀλλὰ ἐλπίζω γενέσθαι πρὸς ὑμᾶς καὶ στόμα πρὸς στόμα λαλῆσαι, ἵνα ἡ χαρὰ ὑμῶν πεπληρωμένη ᾖ."
          },
          {
            "n": 13,
            "t": "Ἀσπάζεταί σε τὰ τέκνα τῆς ἀδελφῆς σου τῆς ἐκλεκτῆς."
          }
        ],
